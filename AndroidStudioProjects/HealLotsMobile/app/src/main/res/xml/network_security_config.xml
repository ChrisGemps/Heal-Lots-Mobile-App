<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Allow cleartext traffic for development backend on emulator/localhost -->
    <domain-config cleartextTrafficPermitted="true">
        <!-- Allow cleartext to 10.0.2.2 (emulator's way to reach localhost) -->
        <domain includeSubdomains="true">10.0.2.2</domain>
        <!-- Also allow cleartext to localhost for development -->
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">127.0.0.1</domain>
    </domain-config>
    <!-- By default, cleartext is not permitted in production -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">*.com</domain>
    </domain-config>
</network-security-config>

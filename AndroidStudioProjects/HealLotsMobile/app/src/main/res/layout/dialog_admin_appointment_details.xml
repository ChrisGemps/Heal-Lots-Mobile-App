<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/appointment_modal_background"
        android:orientation="vertical"
        android:padding="22dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="serif"
                android:text="Appointment Details"
                android:textColor="@color/text_primary"
                android:textSize="24sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/adminDetailHeaderCloseBtn"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@android:color/transparent"
                android:text="✕"
                android:textColor="@color/text_secondary"
                android:textSize="16sp"
                android:textStyle="bold" />

        </LinearLayout>

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:columnCount="2">

            <TextView android:text="PATIENT NAME" android:textColor="@color/text_secondary" android:textSize="11sp" android:textStyle="bold" />
            <TextView android:id="@+id/adminDetailPatientNameValue" android:paddingBottom="12dp" android:textColor="@color/text_primary" android:textSize="14sp" android:textStyle="bold" />
            <TextView android:text="EMAIL" android:textColor="@color/text_secondary" android:textSize="11sp" android:textStyle="bold" />
            <TextView android:id="@+id/adminDetailEmailValue" android:paddingBottom="12dp" android:textColor="@color/text_primary" android:textSize="14sp" />
            <TextView android:text="PHONE" android:textColor="@color/text_secondary" android:textSize="11sp" android:textStyle="bold" />
            <TextView android:id="@+id/adminDetailPhoneValue" android:paddingBottom="12dp" android:textColor="@color/text_primary" android:textSize="14sp" />
            <TextView android:text="SERVICE" android:textColor="@color/text_secondary" android:textSize="11sp" android:textStyle="bold" />
            <TextView android:id="@+id/adminDetailServiceValue" android:paddingBottom="12dp" android:textColor="@color/text_primary" android:textSize="14sp" android:textStyle="bold" />
            <TextView android:text="SPECIALIST" android:textColor="@color/text_secondary" android:textSize="11sp" android:textStyle="bold" />
            <TextView android:id="@+id/adminDetailSpecialistValue" android:paddingBottom="12dp" android:textColor="@color/text_primary" android:textSize="14sp" android:textStyle="bold" />
            <TextView android:text="DATE" android:textColor="@color/text_secondary" android:textSize="11sp" android:textStyle="bold" />
            <TextView android:id="@+id/adminDetailDateValue" android:paddingBottom="12dp" android:textColor="@color/text_primary" android:textSize="14sp" android:textStyle="bold" />
            <TextView android:text="TIME" android:textColor="@color/text_secondary" android:textSize="11sp" android:textStyle="bold" />
            <TextView android:id="@+id/adminDetailTimeValue" android:paddingBottom="12dp" android:textColor="@color/text_primary" android:textSize="14sp" android:textStyle="bold" />
            <TextView android:text="STATUS" android:textColor="@color/text_secondary" android:textSize="11sp" android:textStyle="bold" />
            <TextView android:id="@+id/adminDetailStatusValue" android:paddingBottom="12dp" android:textColor="@color/text_primary" android:textSize="14sp" android:textStyle="bold" />

        </GridLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="REASON FOR VISIT"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/adminDetailReasonValue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:background="@drawable/appointment_reason_background"
            android:padding="12dp"
            android:textColor="@color/text_primary"
            android:textSize="13sp" />

        <LinearLayout
            android:id="@+id/adminDetailNotesBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/profile_info_background"
            android:orientation="vertical"
            android:padding="12dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Additional Notes"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/adminDetailNotesValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/text_primary"
                android:textSize="12sp" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/adminDetailRescheduleBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/appointment_blue_notice_background"
            android:orientation="vertical"
            android:padding="12dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Reason For Rescheduling"
                android:textColor="@color/status_info_text"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/adminDetailRescheduleReason"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/status_info_text"
                android:textSize="12sp" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/adminDetailCancellationBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/appointment_red_notice_background"
            android:orientation="vertical"
            android:padding="12dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Reason For Cancelling"
                android:textColor="@color/status_error_text"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/adminDetailCancellationReason"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/status_error_text"
                android:textSize="12sp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/adminDetailActionBtn1"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="Close"
                android:textStyle="bold" />

            <Space
                android:layout_width="8dp"
                android:layout_height="wrap_content" />

            <Button
                android:id="@+id/adminDetailActionBtn2"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="Action"
                android:textStyle="bold" />

            <Space
                android:id="@+id/adminDetailActionSpacer2"
                android:layout_width="8dp"
                android:layout_height="wrap_content" />

            <Button
                android:id="@+id/adminDetailActionBtn3"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="Action"
                android:textStyle="bold" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/adminDetailExtraActionsRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal"
            android:visibility="gone">

            <Button
                android:id="@+id/adminDetailActionBtn4"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="Action"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/light_bg"
    tools:context=".ui.activities.ProfileActivity">

    <!-- Top Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:background="@drawable/hero_gradient_background"
        android:elevation="6dp">

        <Button
            android:id="@+id/profileBackBtn"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="← Back"
            android:textColor="@color/text_light"
            android:textSize="13sp"
            android:textStyle="bold"
            android:background="@android:color/transparent" />

        <Space
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="My Profile"
            android:textColor="@color/text_white"
            android:textSize="16sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Scrollable Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="24dp"
            android:paddingBottom="40dp">

            <!-- Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="356dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="My Profile"
                        android:textColor="@color/text_primary"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Manage your healthcare"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />

                </LinearLayout>

                <Button
                    android:id="@+id/profileEditBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="42dp"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:text="✏ Edit"
                    android:textColor="@android:color/white"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:background="@drawable/button_background" />

            </LinearLayout>

            <!-- Banners -->
            <FrameLayout
                android:id="@+id/profileSuccessBanner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:background="@drawable/card_background_light"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/profileSuccessMessage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="✅ Profile updated!"
                    android:textColor="@color/status_success_text"
                    android:textSize="13sp"
                    android:textStyle="bold" />

            </FrameLayout>

            <FrameLayout
                android:id="@+id/profileErrorBanner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:background="@drawable/card_background_light"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/profileErrorMessage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="⚠️ Error"
                    android:textColor="@color/error_red"
                    android:textSize="13sp"
                    android:textStyle="bold" />

            </FrameLayout>

            <!-- Hero Card -->\
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/hero_gradient_background"
                android:padding="22dp"
                android:layout_marginBottom="16dp"
                android:elevation="2dp">

                <!-- Avatar -->
                <FrameLayout
                    android:id="@+id/profileAvatarContainer"
                    android:layout_width="88dp"
                    android:layout_height="88dp"
                    android:layout_marginEnd="18dp">

                    <ImageView
                        android:id="@+id/profilePhotoImage"
                        android:layout_width="88dp"
                        android:layout_height="88dp"
                        android:background="@drawable/avatar_clip_background"
                        android:clipToOutline="true"
                        android:contentDescription="Profile Photo"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/profilePhotoInitial"
                        android:layout_width="88dp"
                        android:layout_height="88dp"
                        android:background="@drawable/avatar_background"
                        android:gravity="center"
                        android:textColor="@android:color/white"
                        android:textSize="32sp"
                        android:textStyle="bold" />

                </FrameLayout>

                <!-- Info -->
                <LinearLayout
                    android:layout_width="265dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/profile_info_background"
                    android:clipToOutline="true"
                    android:orientation="vertical"
                    android:paddingStart="16dp"
                    android:paddingTop="14dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="14dp">

                    <TextView
                        android:id="@+id/profileNameDisplay"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="User"
                        android:textColor="@android:color/white"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/profileChangePhotoBtn"
                            android:layout_width="wrap_content"
                            android:layout_height="28dp"
                            android:background="@drawable/button_background"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"
                            android:text="Change Picture"
                            android:textColor="@android:color/white"
                            android:textSize="10sp" />

                    </LinearLayout>

                    <TextView
                        android:id="@+id/profilePhotoError"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@android:color/holo_red_light"
                        android:textSize="10sp"
                        android:visibility="gone" />

                </LinearLayout>

            </LinearLayout>

            <!-- Account Info -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_background_light"
                android:padding="20dp"
                android:layout_marginBottom="14dp"
                android:elevation="2dp"
                android:clipToOutline="true">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ACCOUNT"
                    android:textColor="@color/primary_orange"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="14dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="FULL NAME"
                        android:textColor="@color/text_secondary"
                        android:textSize="9sp"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:id="@+id/profileFullNameView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="User"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp" />

                    <EditText
                        android:id="@+id/profileFullNameEdit"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:background="@drawable/edit_text_background"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:visibility="gone" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="EMAIL"
                        android:textColor="@color/text_secondary"
                        android:textSize="9sp"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:id="@+id/profileEmailView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="user@example.com"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp" />

                    <EditText
                        android:id="@+id/profileEmailEdit"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:background="@drawable/edit_text_background"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:visibility="gone" />

                </LinearLayout>

            </LinearLayout>

            <!-- Personal Info -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_background_light"
                android:padding="20dp"
                android:layout_marginBottom="14dp"
                android:elevation="2dp"
                android:clipToOutline="true">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PERSONAL"
                    android:textColor="@color/primary_orange"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="14dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PHONE"
                        android:textColor="@color/text_secondary"
                        android:textSize="9sp"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:id="@+id/profilePhoneView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="+63 900 000 0000"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp" />

                    <EditText
                        android:id="@+id/profilePhoneEdit"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:background="@drawable/edit_text_background"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:visibility="gone" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="BIRTHDAY"
                        android:textColor="@color/text_secondary"
                        android:textSize="9sp"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:id="@+id/profileBirthdayView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Jan 1, 1990"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp" />

                    <EditText
                        android:id="@+id/profileBirthdayEdit"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:background="@drawable/edit_text_background"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:visibility="gone" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="GENDER"
                        android:textColor="@color/text_secondary"
                        android:textSize="9sp"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:id="@+id/profileGenderView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Not specified"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp" />

                    <Spinner
                        android:id="@+id/profileGenderEdit"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:background="@drawable/edit_text_background"
                        android:visibility="gone" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ADDRESS"
                        android:textColor="@color/text_secondary"
                        android:textSize="9sp"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:id="@+id/profileAddressView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Manila"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp" />

                    <EditText
                        android:id="@+id/profileAddressEdit"
                        android:layout_width="match_parent"
                        android:layout_height="80dp"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        android:background="@drawable/edit_text_background"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:gravity="top"
                        android:visibility="gone" />

                </LinearLayout>

                <Button
                    android:id="@+id/profileSaveBtn"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="💾 Save Changes"
                    android:textColor="@android:color/white"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:background="@drawable/button_background"
                    android:layout_marginTop="20dp"
                    android:visibility="gone" />

            </LinearLayout>

            <!-- Security -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_background_light"
                android:padding="20dp"
                android:layout_marginBottom="16dp"
                android:elevation="2dp"
                android:clipToOutline="true">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SECURITY"
                    android:textColor="@color/primary_orange"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="14dp" />

                <!-- View State -->
                <LinearLayout
                    android:id="@+id/passwordViewState"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Password"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="••••••••"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp" />

                    </LinearLayout>

                    <Button
                        android:id="@+id/profileChangePasswordBtn"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:text="🔑 Change"
                        android:textColor="@android:color/white"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:background="@drawable/button_background" />

                </LinearLayout>

                <!-- Edit State -->
                <LinearLayout
                    android:id="@+id/passwordEditState"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <EditText
                        android:id="@+id/profileCurrentPasswordEdit"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:layout_marginTop="12dp"
                        android:layout_marginBottom="12dp"
                        android:background="@drawable/edit_text_background"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:hint="Current Password"
                        android:inputType="textPassword" />

                    <ImageView
                        android:id="@+id/profileCurrentPasswordToggle"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_marginTop="-44dp"
                        android:layout_marginEnd="6dp"
                        android:layout_gravity="end"
                        android:src="@drawable/ic_placeholder"
                        android:scaleType="centerInside" />

                    <EditText
                        android:id="@+id/profileNewPasswordEdit"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:layout_marginBottom="12dp"
                        android:background="@drawable/edit_text_background"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:hint="New Password (min 8 chars)"
                        android:inputType="textPassword" />

                    <ImageView
                        android:id="@+id/profileNewPasswordToggle"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_marginTop="-44dp"
                        android:layout_marginEnd="6dp"
                        android:layout_gravity="end"
                        android:src="@drawable/ic_placeholder"
                        android:scaleType="centerInside" />

                    <ProgressBar
                        android:id="@+id/profilePasswordStrengthBar"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="4dp"
                        android:layout_marginBottom="4dp"
                        android:max="5"
                        android:progress="0" />

                    <TextView
                        android:id="@+id/profilePasswordStrengthText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Weak"
                        android:textColor="@android:color/holo_red_light"
                        android:textSize="10sp"
                        android:layout_marginBottom="12dp" />

                    <EditText
                        android:id="@+id/profileConfirmPasswordEdit"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:layout_marginBottom="12dp"
                        android:background="@drawable/edit_text_background"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:hint="Confirm Password"
                        android:inputType="textPassword" />

                    <ImageView
                        android:id="@+id/profileConfirmPasswordToggle"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_marginTop="-44dp"
                        android:layout_marginEnd="6dp"
                        android:layout_gravity="end"
                        android:src="@drawable/ic_placeholder"
                        android:scaleType="centerInside" />

                    <TextView
                        android:id="@+id/profilePasswordMatchText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textSize="10sp"
                        android:layout_marginBottom="12dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/profileUpdatePasswordBtn"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            android:text="🔒 Update"
                            android:textColor="@android:color/white"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:background="@drawable/button_background" />

                        <Button
                            android:id="@+id/profileCancelPasswordBtn"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_weight="1"
                            android:text="Cancel"
                            android:textColor="@color/primary_orange"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:background="@drawable/button_outline" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

            <Button
                android:id="@+id/profileSignOutBtn"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="40dp"
                android:text="🚪 Sign Out"
                android:textColor="@color/primary_orange"
                android:textSize="15sp"
                android:textStyle="bold"
                android:background="@drawable/button_outline" />

        </LinearLayout>

    </ScrollView>

</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/appointment_modal_background"
    android:orientation="vertical"
    android:padding="22dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="serif"
        android:text="Cancel Appointment"
        android:textColor="@color/text_primary"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="Are you sure you want to cancel this appointment? This action cannot be undone."
        android:textColor="@color/text_secondary"
        android:textSize="13sp" />

    <EditText
        android:id="@+id/cancelReasonInput"
        android:layout_width="match_parent"
        android:layout_height="110dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/edit_text_background"
        android:gravity="top"
        android:hint="Reason for cancellation"
        android:inputType="textMultiLine|textCapSentences"
        android:padding="12dp" />

    <TextView
        android:id="@+id/cancelReasonCounter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:layout_marginTop="6dp"
        android:text="0/200"
        android:textColor="@color/text_secondary"
        android:textSize="11sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:orientation="horizontal">

        <Button android:id="@+id/cancelConfirmBtn" android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1" android:text="✕ Yes, Cancel Appointment" android:textStyle="bold" />
        <Space android:layout_width="8dp" android:layout_height="wrap_content" />
        <Button android:id="@+id/cancelDismissBtn" android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1" android:text="Keep Appointment" android:textStyle="bold" />

    </LinearLayout>

</LinearLayout>

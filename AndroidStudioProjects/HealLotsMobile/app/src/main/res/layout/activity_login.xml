<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/light_bg"
    tools:context=".ui.activities.LoginActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Hero Section (Mobile Header) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/hero_gradient_background"
            android:padding="@dimen/spacing_5xl"
            android:gravity="center">

            <!-- Logo -->

            <!-- Hero Headline -->
            <ImageView
                android:id="@+id/logoImage"
                android:layout_width="350dp"
                android:layout_height="120dp"
                android:layout_marginBottom="@dimen/spacing_lg"
                android:contentDescription="Heal Lots Logo"
                android:scaleType="centerInside"
                android:src="@drawable/logo" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Healing through\nthe art of Hilot"
                android:textAppearance="@style/TextAppearance.HealLots.Heading3"
                android:textColor="@color/text_white"
                android:gravity="center"
                android:layout_marginBottom="@dimen/spacing_lg" />

            <!-- Hero Tagline -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Sign in to book your session\nwith our trusted local hilot specialists."
                android:textAppearance="@style/TextAppearance.HealLots.BodyMedium"
                android:textColor="@color/text_tertiary"
                android:gravity="center"
                android:lineSpacingMultiplier="1.75"
                android:layout_marginBottom="@dimen/spacing_3xl" />

            <!-- Features List -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="start">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="@dimen/spacing_md">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🤲"
                        android:textSize="@dimen/text_lg"
                        android:layout_marginEnd="@dimen/spacing_md" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Skilled hilot practitioners"
                        android:textAppearance="@style/TextAppearance.HealLots.BodySmall"
                        android:textColor="@color/text_tertiary" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="@dimen/spacing_md">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🌿"
                        android:textSize="@dimen/text_lg"
                        android:layout_marginEnd="@dimen/spacing_md" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Traditional Filipino methods"
                        android:textAppearance="@style/TextAppearance.HealLots.BodySmall"
                        android:textColor="@color/text_tertiary" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📅"
                        android:textSize="@dimen/text_lg"
                        android:layout_marginEnd="@dimen/spacing_md" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Easy appointment booking"
                        android:textAppearance="@style/TextAppearance.HealLots.BodySmall"
                        android:textColor="@color/text_tertiary" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Form Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_lg"
            android:background="@color/light_bg">

            <!-- Form Header -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Welcome back"
                android:textAppearance="@style/TextAppearance.HealLots.Heading4"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="@dimen/spacing_sm" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Sign in to your Heal Lots account"
                android:textAppearance="@style/TextAppearance.HealLots.BodySmall"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="@dimen/spacing_lg" />

            <!-- Error Banner -->
            <FrameLayout
                android:id="@+id/errorBanner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:background="@color/error_bg"
                android:padding="@dimen/spacing_md"
                android:layout_marginBottom="@dimen/spacing_lg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⚠️"
                        android:textSize="@dimen/text_md"
                        android:layout_marginEnd="@dimen/spacing_md" />

                    <TextView
                        android:id="@+id/errorMessage"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textAppearance="@style/TextAppearance.HealLots.BodySmall"
                        android:textColor="@color/error_red"
                        android:text="Invalid email or password." />
                </LinearLayout>
            </FrameLayout>

            <!-- Email Field -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Email Address"
                android:textAppearance="@style/TextAppearance.HealLots.Label"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="@dimen/spacing_sm"
                android:letterSpacing="0.01" />

            <EditText
                android:id="@+id/emailEditText"
                android:layout_width="match_parent"
                android:layout_height="@dimen/input_height"
                android:hint="Enter Your Email Address"
                android:inputType="textEmailAddress"
                android:padding="@dimen/input_padding"
                android:background="@drawable/edit_text_background"
                android:textAppearance="@style/TextAppearance.HealLots.BodyMedium"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary"
                android:layout_marginBottom="@dimen/spacing_lg" />

            <!-- Password Field -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Password"
                android:textAppearance="@style/TextAppearance.HealLots.Label"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="@dimen/spacing_sm"
                android:letterSpacing="0.01" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="@dimen/input_height"
                android:background="@drawable/edit_text_background"
                android:layout_marginBottom="@dimen/spacing_lg">

                <EditText
                    android:id="@+id/passwordEditText"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:hint="Enter Your Password"
                    android:inputType="textPassword"
                    android:padding="@dimen/input_padding"
                    android:background="@android:color/transparent"
                    android:textAppearance="@style/TextAppearance.HealLots.BodyMedium"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_secondary" />

                <ImageButton
                    android:id="@+id/passwordToggleButton"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:contentDescription="Toggle password visibility"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@android:drawable/ic_menu_view"
                    android:layout_gravity="end"
                    android:scaleType="centerInside" />
            </FrameLayout>

            <!-- Login Button -->
            <Button
                android:id="@+id/loginButton"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:text="Sign In"
                android:textAppearance="@style/TextAppearance.HealLots.Label"
                android:textColor="@color/text_white"
                android:background="@drawable/button_background"
                android:layout_marginBottom="@dimen/spacing_lg"
                android:elevation="@dimen/card_elevation_high" />

            <!-- Register Link -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Don't have an account? "
                    android:textAppearance="@style/TextAppearance.HealLots.BodySmall"
                    android:textColor="@color/text_secondary" />

                <TextView
                    android:id="@+id/registerLink"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Create one"
                    android:textAppearance="@style/TextAppearance.HealLots.Label"
                    android:textColor="@color/primary_orange"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

</ScrollView>


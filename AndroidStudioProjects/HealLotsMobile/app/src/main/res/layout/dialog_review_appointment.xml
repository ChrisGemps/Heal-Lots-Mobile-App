<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/appointment_modal_background"
    android:orientation="vertical"
    android:padding="22dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="serif"
        android:text="Leave Review"
        android:textColor="@color/text_primary"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView android:id="@+id/reviewServiceText" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="14dp" android:textColor="@color/text_primary" android:textSize="15sp" android:textStyle="bold" />
    <TextView android:id="@+id/reviewSpecialistText" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:textColor="@color/text_secondary" android:textSize="13sp" />

    <LinearLayout
        android:id="@+id/reviewBanner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="@drawable/appointment_success_banner_background"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="12dp"
        android:visibility="gone">

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="✓" android:textColor="@color/status_success_text" android:textSize="16sp" android:textStyle="bold" />
        <TextView android:id="@+id/reviewBannerText" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:text="Review already submitted." android:textColor="@color/status_success_text" android:textSize="12sp" android:textStyle="bold" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/reviewStarsRow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:orientation="horizontal">

        <TextView android:id="@+id/reviewStar1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="★" android:textSize="28sp" android:textColor="#D1C6B2" />
        <TextView android:id="@+id/reviewStar2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:text="★" android:textSize="28sp" android:textColor="#D1C6B2" />
        <TextView android:id="@+id/reviewStar3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:text="★" android:textSize="28sp" android:textColor="#D1C6B2" />
        <TextView android:id="@+id/reviewStar4" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:text="★" android:textSize="28sp" android:textColor="#D1C6B2" />
        <TextView android:id="@+id/reviewStar5" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:text="★" android:textSize="28sp" android:textColor="#D1C6B2" />

    </LinearLayout>

    <TextView
        android:id="@+id/reviewRatingLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Tap a star to rate"
        android:textColor="@color/text_secondary"
        android:textSize="13sp" />

    <EditText
        android:id="@+id/reviewFeedbackInput"
        android:layout_width="match_parent"
        android:layout_height="110dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/edit_text_background"
        android:gravity="top"
        android:hint="Share optional feedback"
        android:inputType="textMultiLine|textCapSentences"
        android:padding="12dp" />

    <TextView
        android:id="@+id/reviewCounter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:layout_marginTop="6dp"
        android:text="0/500"
        android:textColor="@color/text_secondary"
        android:textSize="11sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:orientation="horizontal">

        <Button android:id="@+id/reviewSubmitBtn" android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1" android:text="✓ Submit Review" android:textStyle="bold" />
        <Space android:layout_width="8dp" android:layout_height="wrap_content" />
        <Button android:id="@+id/reviewCancelBtn" android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1" android:text="Cancel" android:textStyle="bold" />

    </LinearLayout>

</LinearLayout>

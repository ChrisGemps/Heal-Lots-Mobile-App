<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.HealLots" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="colorPrimary">@color/primary_purple</item>
        <item name="colorPrimaryDark">@color/primary_purple_dark</item>
        <item name="colorAccent">@color/primary_orange</item>
    </style>

    <!-- Backward compatibility -->
    <style name="Theme.HealLotsMobile" parent="Theme.HealLots" />

    <!-- Base Text Styles -->
    <style name="TextAppearance.HealLots.HeadingXL" parent="TextAppearance.AppCompat">
        <item name="android:textSize">@dimen/text_7xl</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.HealLots.Heading1" parent="TextAppearance.AppCompat">
        <item name="android:textSize">@dimen/text_6xl</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.HealLots.Heading2" parent="TextAppearance.AppCompat">
        <item name="android:textSize">@dimen/text_4xl</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.HealLots.Heading3" parent="TextAppearance.AppCompat">
        <item name="android:textSize">@dimen/text_3xl</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.HealLots.Heading4" parent="TextAppearance.AppCompat">
        <item name="android:textSize">@dimen/text_2xl</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.HealLots.Heading5" parent="TextAppearance.AppCompat">
        <item name="android:textSize">@dimen/text_xl</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.HealLots.BodyLarge" parent="TextAppearance.AppCompat">
        <item name="android:textSize">@dimen/text_lg</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.HealLots.BodyMedium" parent="TextAppearance.AppCompat">
        <item name="android:textSize">@dimen/text_md</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.HealLots.BodySmall" parent="TextAppearance.AppCompat">
        <item name="android:textSize">@dimen/text_sm</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="TextAppearance.HealLots.Label" parent="TextAppearance.AppCompat">
        <item name="android:textSize">@dimen/text_sm</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Button Styles -->
    <style name="ButtonStyle.Primary" parent="@style/Widget.AppCompat.Button.Colored">
        <item name="android:textSize">@dimen/text_md</item>
        <item name="android:textColor">@color/text_white</item>
        <item name="android:textStyle">bold</item>
        <item name="android:layout_height">@dimen/button_height</item>
        <item name="android:layout_marginStart">@dimen/spacing_lg</item>
        <item name="android:layout_marginEnd">@dimen/spacing_lg</item>
        <item name="android:paddingStart">@dimen/spacing_lg</item>
        <item name="android:paddingEnd">@dimen/spacing_lg</item>
    </style>

    <!-- Input Field Styles -->
    <style name="EditTextStyle" parent="Widget.AppCompat.EditText">
        <item name="android:textSize">@dimen/text_md</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textColorHint">@color/text_secondary</item>
        <item name="android:paddingStart">@dimen/spacing_lg</item>
        <item name="android:paddingEnd">@dimen/spacing_lg</item>
        <item name="android:paddingTop">@dimen/spacing_md</item>
        <item name="android:paddingBottom">@dimen/spacing_md</item>
    </style>

    <!-- Card Styles -->
    <style name="CardStyle" parent="CardView">
        <item name="cardCornerRadius">@dimen/corner_md</item>
        <item name="cardElevation">@dimen/card_elevation</item>
        <item name="cardBackgroundColor">@color/light_bg_white</item>
    </style>

    <!-- Divider -->
    <style name="DividerStyle">
        <item name="android:layout_height">@dimen/stroke_thin</item>
        <item name="android:background">@color/border_light</item>
    </style>

</resources>